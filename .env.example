# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (production: Vercel Postgres, Supabase, Railway, etc.)
# For local dev with docker-compose: postgresql://postgres:password@localhost:5432/xenith_db
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Only needed when DATABASE_URL points at a connection pooler (e.g. Vercel Postgres pgBouncer).
# Set to the direct (non-pooled) URL so Prisma Migrate works correctly.
# If using a plain Postgres URL, copy the same value as DATABASE_URL.
# DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"

# Full public URL of your deployment (no trailing slash).
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# ─── Admin setup ──────────────────────────────────────────────────────────────
# Used by the seed script and the /api/auth/register-admin endpoint.
# Change ADMIN_SETUP_KEY to something unguessable before deploying.
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="change-this-to-a-strong-password"
ADMIN_SETUP_KEY="change-this-to-a-random-unguessable-key"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your key at resend.com — required for transactional emails.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ─── Cloudflare R2 storage (product images) ───────────────────────────────────
# Optional — only required if you use product image uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
# R2_ENDPOINT=""         # optional — defaults to https://{accountId}.r2.cloudflarestorage.com
# R2_REGION=""           # optional — defaults to "auto"
# R2_PRODUCTS_PREFIX=""  # optional — defaults to "products"
